/* ============================================================
   Detail Page Styles
   ============================================================ */

.page-detail {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ---- Loading ---- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a6fb5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ---- Content ---- */
.content {
  padding-bottom: 40rpx;
}

/* ---- Header ---- */
.detail-header {
  margin-top: 0;
  border-radius: 0 0 16rpx 16rpx;
}

.detail-meta {
  margin-bottom: 16rpx;
}

.share-row {
  margin-top: 10rpx;
}

.share-row .btn {
  display: inline-flex;
}

/* ---- Block Title ---- */
.block-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.block-icon {
  font-size: 34rpx;
  margin-right: 12rpx;
}

/* ---- TL;DR ---- */
.tldr-point {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #fafafa;
}

.tldr-point:last-child {
  border-bottom: none;
}

.tldr-index {
  font-weight: 700;
  color: #1a6fb5;
  min-width: 36rpx;
  font-size: 28rpx;
}

.tldr-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* ---- Takeaways ---- */
.takeaway-point {
  display: flex;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #fafafa;
}

.takeaway-point:last-child {
  border-bottom: none;
}

.takeaway-num {
  font-weight: 700;
  color: #faad14;
  min-width: 36rpx;
  font-size: 28rpx;
}

.takeaway-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  flex: 1;
}

/* ---- Section Card ---- */
.section-card {
  padding: 0;
}

.section-header {
  padding: 24rpx 30rpx;
}

.section-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #1a6fb5, #3b9ad5);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.item-count {
  font-size: 24rpx;
  color: #aaa;
  margin-left: 10rpx;
}

.collapse-icon {
  font-size: 22rpx;
  color: #999;
  transition: transform 0.3s;
}

.collapse-icon.collapsed {
  transform: rotate(-90deg);
}

/* ---- Section Body ---- */
.section-body {
  transition: max-height 0.3s ease;
  overflow: hidden;
}

.section-body.hidden {
  max-height: 0;
}

/* ---- News Item ---- */
.news-item {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.news-item:last-child {
  padding-bottom: 24rpx;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.news-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 14rpx;
}

/* ---- News Meta ---- */
.news-meta {
  margin-bottom: 8rpx;
}

.score-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.source-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #f0f6fb;
  color: #1a6fb5;
  font-size: 22rpx;
  border-radius: 6rpx;
  border: 1rpx solid #d6e8fa;
}

/* ---- URL ---- */
.news-url {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  margin-top: 6rpx;
}

.url-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.url-text {
  font-size: 24rpx;
  color: #1a6fb5;
  word-break: break-all;
  text-decoration: underline;
  flex: 1;
}

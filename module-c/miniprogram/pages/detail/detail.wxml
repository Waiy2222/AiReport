<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:if="{{!loading && briefing}}">
    <!-- 标题区 -->
    <view class="detail-header">
      <view class="detail-type {{briefing.type}}">{{typeText}}</view>
      <view class="detail-date">{{dateText}}</view>
    </view>

    <!-- TL;DR 要点 -->
    <view class="section-block">
      <view class="section-title">TL;DR 要点</view>
      <view
        wx:for="{{briefing.tl_dr}}"
        wx:key="*this"
        class="tl-item"
      >
        <view class="tl-dot"></view>
        <view>{{item}}</view>
      </view>
    </view>

    <!-- 分类条目 -->
    <view
      wx:for="{{briefing.sections}}"
      wx:for-index="i"
      wx:key="title"
      class="section-block"
    >
      <view
        class="section-header"
        data-index="{{i}}"
        bindtap="onSectionToggle"
      >
        <view class="section-title">{{item.section_title}}</view>
        <view class="section-toggle">{{sectionsExpanded[i] ? '收起' : '展开'}}</view>
      </view>

      <view wx:if="{{sectionsExpanded[i]}}" class="section-items">
        <view
          wx:for="{{item.items}}"
          wx:for-item="article"
          wx:key="title"
          class="article-card"
        >
          <view class="article-title">{{article.title}}</view>
          <image
            wx:if="{{article.image_url && !article._imgHide}}"
            src="{{article.image_url}}"
            mode="widthFix"
            class="article-image"
            lazy-load
            binderror="onImageError"
            data-section="{{i}}"
            data-index="{{index}}"
          />
          <view class="article-summary">{{article.summary}}</view>
          <!-- Phase 3: AI 三方观点辩论卡片 -->
          <view wx:if="{{article.debate}}" class="debate-card">
            <view class="debate-header">🎭 AI三方观点</view>
            <view class="debate-views">
              <view wx:if="{{article.debate.tech_view}}" class="debate-view debate-tech">
                <view class="debate-label">🔧 技术视角</view>
                <view class="debate-text">{{article.debate.tech_view}}</view>
              </view>
              <view wx:if="{{article.debate.biz_view}}" class="debate-view debate-biz">
                <view class="debate-label">💼 商业视角</view>
                <view class="debate-text">{{article.debate.biz_view}}</view>
              </view>
              <view wx:if="{{article.debate.social_view}}" class="debate-view debate-social">
                <view class="debate-label">🌍 社会视角</view>
                <view class="debate-text">{{article.debate.social_view}}</view>
              </view>
            </view>
            <view wx:if="{{article.debate.controversy > 0}}" class="controversy-bar">
              <view class="controversy-label">争议度</view>
              <view class="controversy-track">
                <view class="controversy-fill" style="width: {{article.debate.controversy * 10}}%"></view>
              </view>
              <view class="controversy-value">{{article.debate.controversy}}/10</view>
            </view>
          </view>
          <view class="article-meta">
            <text class="tag">{{article.source}}</text>
            <text class="tag" wx:for="{{article.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text>
            <text class="score">评分 {{article.score}}</text>
          </view>
          <view
            wx:if="{{article.url}}"
            class="article-link"
            data-url="{{article.url}}"
            bindtap="onLinkTap"
          >复制原文链接</view>
        </view>
      </view>
    </view>

    <!-- 关键趋势 -->
    <view wx:if="{{briefing.key_takeaways.length > 0}}" class="section-block takeaways">
      <view class="section-title">关键趋势信号</view>
      <view
        wx:for="{{briefing.key_takeaways}}"
        wx:key="*this"
        class="takeaway-item"
      >{{item}}</view>
    </view>
  </block>

  <view wx:if="{{!loading && !briefing}}" class="empty-state">简报不存在</view>
</view>

# ============================================================
# AI 资讯早报/晚报智能体 — 环境变量模板
# 复制为 .env 并填入实际值
# ============================================================

# PostgreSQL
POSTGRES_DB=ai_news
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Nginx
NGINX_PORT=80

# DeepSeek API（模块 B）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 微信小程序（模块 C）
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_wechat_secret

# 知乎（模块 D）
ZHIHU_CLIENT_ID=your_zhihu_client_id
ZHIHU_CLIENT_SECRET=your_zhihu_client_secret

# CSDN（模块 D）
CSDN_ACCESS_TOKEN=your_csdn_access_token

# 微信公众号（模块 D）
WEIXIN_OA_APPID=wx_your_oa_appid
WEIXIN_OA_SECRET=your_oa_secret

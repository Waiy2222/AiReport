# ============================================================
# AI 资讯早报/晚报智能体 — 环境变量模板
# 复制为 .env 并填入实际值
# ============================================================

# PostgreSQL (Phase 2: 使用 pgvector 镜像)
POSTGRES_DB=ai_news
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Nginx
NGINX_PORT=80

# ---------- DeepSeek API（模块 A/B/E — LLM 调用）----------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------- Embedding API（模块 A — RAG 向量检索）----------
# 默认复用 DeepSeek，也可换 OpenAI 或本地 embedding
EMBEDDING_PROVIDER=deepseek
EMBEDDING_API_KEY=sk-your-deepseek-api-key
# EMBEDDING_MODEL=text-embedding-3-small

# ---------- 微信小程序（模块 C）----------
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_wechat_secret
# 订阅消息模板 ID（在微信公众平台申请）
WX_TEMPLATE_ID=your_template_id

# ---------- 微信公众号（模块 C + D）----------
WEIXIN_OA_APPID=wx_your_oa_appid
WEIXIN_OA_SECRET=your_oa_secret
# 公众号消息回调 Token（模块 C 签名验证用）
WEIXIN_OA_TOKEN=your_token

# ---------- H5 页面基础地址（模块 C — 偏好设置页）----------
H5_BASE_URL=http://localhost:8003/h5

# ---------- 知乎（模块 D）----------
ZHIHU_CLIENT_ID=your_zhihu_client_id
ZHIHU_CLIENT_SECRET=your_zhihu_client_secret

# ---------- CSDN（模块 D）----------
CSDN_USERNAME=your_csdn_username
CSDN_PASSWORD=your_csdn_password

# ---------- Unsplash API（模块 B — 配图搜索）----------
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ---------- 阿里云百炼 API（模块 F — 视频理解，国内可用）----------
BAILIAN_API_KEY=sk-your-bailian-api-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-vl-max

# ---------- Bilibili / Pexels（模块 F — 视频素材搜索，国内可用）----------
# BILIBILI_COOKIE=your_bilibili_cookie  # B站搜索（可选）
PEXELS_API_KEY=your_pexels_api_key

# ---------- 模块 F 视频输出目录 ----------
VIDEO_OUTPUT_DIR=./output
VIDEO_DOWNLOAD_DIR=./downloads

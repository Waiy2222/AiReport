.detail-header {
  text-align: center;
  padding: 20px 0;
}

.detail-type {
  display: inline-block;
  padding: 4px 16px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
}

.detail-type.morning {
  background: #fff3e0;
  color: #e67e22;
}

.detail-type.evening {
  background: #e8eaf6;
  color: #5c6bc0;
}

.detail-date {
  font-size: 13px;
  color: #999;
}

.section-block {
  margin-bottom: 20px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
}

.section-title {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a2e;
}

.section-toggle {
  font-size: 13px;
  color: #4a90d9;
}

.tl-item {
  display: flex;
  align-items: baseline;
  padding: 8px 0;
  font-size: 14px;
  line-height: 1.6;
  color: #444;
}

.tl-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4a90d9;
  margin-right: 10px;
  flex-shrink: 0;
}

.article-card {
  background: #fff;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}

.article-title {
  font-size: 15px;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 6px;
}

.article-image {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 8px;
}

.article-summary {
  font-size: 13px;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8px;
}

.article-meta {
  margin-bottom: 6px;
}

.score {
  font-size: 11px;
  color: #e67e22;
  margin-left: 8px;
}

.article-link {
  font-size: 12px;
  color: #4a90d9;
  padding: 4px 0;
}

.takeaways {
  background: #f8f9ff;
  border-radius: 12px;
  padding: 16px;
}

.takeaway-item {
  font-size: 14px;
  color: #5c6bc0;
  padding: 6px 0;
  line-height: 1.6;
}

/* Phase 3: AI 三方观点辩论卡片 */
.debate-card {
  margin-top: 10px;
  border: 1px solid #e8e8e8;
  border-radius: 10px;
  overflow: hidden;
}

.debate-header {
  font-size: 13px;
  font-weight: 600;
  padding: 8px 12px;
  background: #f5f3ff;
  color: #6c5ce7;
  border-bottom: 1px solid #e8e8e8;
}

.debate-views {
  display: flex;
  flex-direction: row;
}

.debate-view {
  flex: 1;
  padding: 8px 10px;
  min-height: 80px;
}

.debate-view.debate-tech {
  background: #f0f5ff;
  border-right: 1px solid #e0e8f5;
}

.debate-view.debate-biz {
  background: #fff8f0;
  border-right: 1px solid #f0e8d8;
}

.debate-view.debate-social {
  background: #f0fff4;
}

.debate-label {
  font-size: 11px;
  font-weight: 600;
  margin-bottom: 4px;
}

.debate-tech .debate-label { color: #2e5c9e; }
.debate-biz .debate-label { color: #c07830; }
.debate-social .debate-label { color: #2e7d4f; }

.debate-text {
  font-size: 11px;
  color: #555;
  line-height: 1.5;
  word-break: break-all;
}

.controversy-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: #fafafa;
  border-top: 1px solid #e8e8e8;
}

.controversy-label {
  font-size: 11px;
  color: #999;
  flex-shrink: 0;
}

.controversy-track {
  flex: 1;
  height: 6px;
  background: #eee;
  border-radius: 3px;
  overflow: hidden;
}

.controversy-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ecb71, #fac858, #e8634a);
  border-radius: 3px;
  transition: width 0.3s;
}

.controversy-value {
  font-size: 11px;
  color: #666;
  flex-shrink: 0;
}

<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="avatar">U</view>
    <view class="user-info">
      <view class="user-id">{{openidMasked}}</view>
      <view class="user-hint">已登录</view>
    </view>
  </view>

  <!-- 标签偏好 -->
  <view class="settings-block">
    <view class="settings-title">我的兴趣标签</view>
    <view class="tag-section">
      <view class="tag-hint" wx:if="{{selectedTags.length === 0}}">未选择标签，将推送综合简报</view>
      <view class="tag-hint selected" wx:else>已选 {{selectedTags.length}} 个标签，将推送个性化内容</view>
      <view class="tag-grid">
        <view
          class="tag-chip {{item.selected ? 'selected' : ''}}"
          wx:for="{{allTags}}"
          wx:key="tag"
          data-tag="{{item.tag}}"
          bindtap="onTagTap"
        >
          <view class="tag-label">{{item.label_zh}}</view>
          <view class="tag-desc">{{item.description}}</view>
        </view>
      </view>
      <button class="save-btn" bindtap="onSavePreferences">保存偏好</button>
    </view>
  </view>

  <!-- Phase 3: 信源健康度 -->
  <view class="settings-block">
    <view class="settings-title">
      信源健康度
      <view class="health-pending-badge" wx:if="{{pendingRecommendations > 0}}">
        🔔 {{pendingRecommendations}}个新信源待审核
      </view>
    </view>
    <view class="health-list">
      <view
        class="health-item"
        wx:for="{{sourceHealth}}"
        wx:key="tag"
      >
        <view class="health-dot {{item.health}}"></view>
        <view class="health-tag">{{item.label_zh || item.tag}}</view>
        <view class="health-count">{{item.count}}条</view>
      </view>
    </view>
    <view class="health-hint" wx:if="{{sourceHealth.length === 0}}">
      加载中...
    </view>
  </view>

  <!-- 订阅设置 -->
  <view class="settings-block">
    <view class="settings-title">推送订阅</view>

    <view class="setting-item">
      <view class="setting-label">
        <view class="setting-name">每日早报</view>
        <view class="setting-desc">每天早上 8:00 推送</view>
      </view>
      <switch
        checked="{{morningEnabled}}"
        bindchange="onToggleMorning"
        color="#4a90d9"
      />
    </view>

    <view class="setting-item">
      <view class="setting-label">
        <view class="setting-name">每日晚报</view>
        <view class="setting-desc">每天晚上 20:00 推送</view>
      </view>
      <switch
        checked="{{eveningEnabled}}"
        bindchange="onToggleEvening"
        color="#4a90d9"
      />
    </view>
  </view>

  <!-- 关于 -->
  <view class="settings-block">
    <view class="setting-item" bindtap="onAbout">
      <view class="setting-label">
        <view class="setting-name">关于</view>
        <view class="setting-desc">AI 资讯简报 v2.0</view>
      </view>
      <view class="arrow">></view>
    </view>
  </view>
</view>

/* ============================================================
   Mine Page Styles
   ============================================================ */

.page-mine {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 40rpx;
}

/* ---- User Header ---- */
.user-header {
  display: flex;
  align-items: center;
  padding: 50rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #1a6fb5 0%, #3b9ad5 100%);
  color: #fff;
}

.avatar-wrapper {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 26rpx;
}

.avatar-icon {
  font-size: 56rpx;
  color: #fff;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-status {
  font-size: 24rpx;
}

/* ---- Subscription Card ---- */
.subscription-card {
  padding: 0;
  margin-top: -30rpx;
  z-index: 1;
  position: relative;
}

.card-header-row {
  padding: 30rpx;
}

.card-header-icon {
  font-size: 40rpx;
  margin-right: 14rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-active {
  background: #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
}

.dot-inactive {
  background: #ddd;
}

.subscription-card .divider {
  margin: 0;
}

/* ---- Setting Row ---- */
.setting-row {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.setting-row:last-of-type {
  border-bottom: none;
}

.setting-icon {
  font-size: 40rpx;
  margin-right: 18rpx;
}

.setting-row .title-sm {
  font-size: 28rpx;
}

/* ---- Action Button ---- */
.subscribe-action {
  padding: 30rpx;
}

.subscribe-action .btn {
  border-radius: 16rpx;
}

/* ---- About Card ---- */
.about-card {
  padding: 0;
}

.about-row {
  padding: 30rpx;
}

.about-icon {
  font-size: 36rpx;
  margin-right: 18rpx;
}

.about-arrow {
  font-size: 30rpx;
}

.about-card .divider {
  margin: 0;
}

/* ---- Footer ---- */
.footer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0 20rpx;
}

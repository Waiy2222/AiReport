<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索简报内容..."
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 结果数 -->
  <view wx:if="{{keyword}}" class="result-hint">找到 {{total}} 条结果</view>

  <!-- 列表 -->
  <view wx:if="{{list.length > 0}}">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="card history-card"
      data-id="{{item.id}}"
      bindtap="onItemTap"
    >
      <view class="card-header">
        <view class="card-type {{item.type}}">{{item.type === 'morning' ? '早报' : '晚报'}}</view>
        <view class="card-subtitle">{{item.dateText}}</view>
      </view>
      <view
        wx:for="{{item.tlDrPreview}}"
        wx:for-item="point"
        wx:key="*this"
        class="history-tl"
      >{{point}}</view>
      <view wx:if="{{item.tl_dr.length > 3}}" class="more-hint">... 共 {{item.tl_dr.length}} 条要点</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 到底 -->
  <view wx:if="{{noMore && list.length > 0}}" class="loading">已加载全部</view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && list.length === 0}}">
    <view wx:if="{{keyword}}" class="empty-state">未找到相关简报</view>
    <view wx:else class="empty-state">暂无历史简报</view>
  </view>
</view>
